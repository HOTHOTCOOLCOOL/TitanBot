{
  "agents": {
    "defaults": {
      "model": "anthropic/claude-3-5-sonnet-latest",
      "language": "zh",
      "temperature": 0.7,
      "maxTokens": 8192,
      "maxToolIterations": 20,
      "memoryWindow": 50
    },
    "vlm": {
      "enabled": true,
      "model": "dashscope/qwen-vl-max"
    },
    "browser": {
      "enabled": true,
      "headless": true,
      "executablePath": "",
      "defaultTimeoutMs": 30000,
      "viewportWidth": 1920,
      "viewportHeight": 1080,
      "maxPages": 5,
      "sessionTtlHours": 24,
      "trustedDomains": [],
      "blockInternalIps": true
    },
    "streaming": {
      "enabled": true
    },
    "memoryFeatures": {
      "reflectionEnabled": true,
      "knowledgeGraphEnabled": true,
      "visualMemoryEnabled": true,
      "experienceEnabled": true
    }
  },
  "providers": {
    "deepseek": { "apiKey": "your_deepseek_api_key_here" },
    "openai": { "apiKey": "your_openai_api_key_here" },
    "anthropic": { "apiKey": "your_anthropic_api_key_here" },
    "gemini": { "apiKey": "your_gemini_api_key_here" },
    "siliconflow": { "apiKey": "your_siliconflow_api_key_here" },
    "custom": {
      "apiKey": "ollama",
      "apiBase": "http://localhost:11434/v1"
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "your_telegram_bot_token_here",
      "allowFrom": []
    },
    "discord": {
      "enabled": false,
      "token": "your_discord_bot_token_here",
      "allowFrom": []
    },
    "feishu": {
      "enabled": false,
      "appId": "your_feishu_app_id",
      "appSecret": "your_feishu_app_secret"
    },
    "slack": {
      "enabled": false,
      "botToken": "xoxb-your-bot-token",
      "appToken": "xapp-your-app-token"
    }
  },
  "gateway": {
    "host": "127.0.0.1",
    "port": 18790
  },
  "tools": {
    "web": {
      "search": { "apiKey": "your_brave_search_api_key_here" }
    }
  }
}
