# Nanobot Configuration Template
# Copy this file to .env and fill in your keys

# --- Agent Defaults ---
# Default model name (path format: provider/model)
NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-3-5-sonnet-latest
# NANOBOT_AGENTS__DEFAULTS__MODEL=deepseek/deepseek-chat
# NANOBOT_AGENTS__DEFAULTS__MODEL=openai/gpt-4o

# Other agent defaults
NANOBOT_AGENTS__DEFAULTS__TEMPERATURE=0.7
NANOBOT_AGENTS__DEFAULTS__LANGUAGE=zh

# --- Providers ---
# DeepSeek
NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=your_deepseek_api_key_here
# NANOBOT_PROVIDERS__DEEPSEEK__API_BASE=https://api.deepseek.com

# OpenAI
NANOBOT_PROVIDERS__OPENAI__API_KEY=your_openai_api_key_here

# Anthropic
NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=your_anthropic_api_key_here

# SiliconFlow
NANOBOT_PROVIDERS__SILICONFLOW__API_KEY=your_siliconflow_api_key_here

# Custom OpenAI-compatible Provider (e.g., Local LLM via Ollama/vLLM)
NANOBOT_PROVIDERS__CUSTOM__API_KEY=ollama
NANOBOT_PROVIDERS__CUSTOM__API_BASE=http://10.18.34.60:5888/v1

# --- Gateway ---
NANOBOT_GATEWAY__PORT=18790
NANOBOT_GATEWAY__HOST=0.0.0.0

# --- Tools ---
NANOBOT_TOOLS__WEB__SEARCH__API_KEY=your_brave_search_key_here

# --- SSRS Report Skill (内网报表系统) ---
# 认证优先级：
#   1. 自动SSPI（当前 Windows 登录态，无需任何配置）               [BEST]
#   2. Windows Credential Manager： python fetch_report.py --setup-credentials  [SAFE]
#   3. 下方明文配置（不推荐，建议改用上面两种方式）             [AVOID]
# SSRS_USER=your_windows_username
# SSRS_PASSWORD=your_windows_password
# SSRS_DOMAIN=your_ad_domain
